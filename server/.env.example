PORT=4000
NODE_ENV=development

# PostgreSQL (обязательно)
# Локально после docker compose up -d из корня:
DATABASE_URL=postgres://hozyan:hozyan_local@localhost:5433/hozyan

# Облако (Neon / Supabase / Render): вставьте выданную строку, часто с ?sslmode=require
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# DATABASE_SSL=true
# PGSSL_STRICT=true

JWT_SECRET=change_me

# Локальная разработка (фронт на :5173)
CORS_ORIGIN=http://localhost:5173

# --- Продакшен (один сервис: API + статика, см. render.yaml) ---
# NODE_ENV=production
# CORS_ORIGIN не нужен, если фронт на том же домене
# PUBLIC_API_URL=https://ваш-сайт.onrender.com
# RENDER_EXTERNAL_URL подставляется Render автоматически

# --- Продакшен (раздельный фронт, см. render-split.yaml) ---
# CORS_ORIGIN=https://ваш-фронт.onrender.com
# PUBLIC_API_URL=https://ваш-api.onrender.com

# На Render без постоянного диска — отключить загрузку файлов (используйте URL картинок)
# DISABLE_FILE_UPLOAD=true

# Контакты на сайте
SITE_PHONE=+7 (495) 123-45-67
SITE_PHONE_TEL=+74951234567
SITE_EMAIL=info@hozyan.ru
SITE_ADDRESS=с. Беляевка, ул. Торговая, д. 13
